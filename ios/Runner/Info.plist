<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Salary Topup</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>SalaryTopup</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fbAPP-ID</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>razorpay</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Queried URL Schemes for UPI/Payment Apps -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>phonepe</string>
		<string>paytm</string>
		<string>tez</string>
		<string>gpay</string>
		<string>upi</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- Camera Permission -->
	<key>NSCameraUsageDescription</key>
	<string>Salary Topup needs camera access to capture documents required for your loan application (KYC verification).</string>

	<!-- Photo Library Permission -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Salary Topup needs photo library access to upload documents required for your loan application (KYC verification).</string>

	<!-- Photo Library Add Permission -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Salary Topup needs permission to save documents to your photo library.</string>

	<!-- Location Permission -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Salary Topup uses your location to verify your address and comply with RBI guidelines for loan processing.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Salary Topup uses your location to verify your address and comply with RBI guidelines for loan processing.</string>

	<!-- Face ID Permission -->
	<key>NSFaceIDUsageDescription</key>
	<string>Salary Topup uses Face ID for secure and quick login to your account.</string>

	<!-- Microphone (if needed for video KYC) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Salary Topup needs microphone access for video KYC verification process.</string>

	<!-- Contacts (if applicable) -->
	<!-- <key>NSContactsUsageDescription</key> -->
	<!-- <string>Salary Topup needs contacts access for emergency contact verification.</string> -->

	<!-- App Transport Security -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>

	<!-- Firebase / Push Notifications -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>

	<!-- UI Settings -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- Portrait only for loan app (Apple policy recommends) -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>

	<!-- ITSAppUsesNonExemptEncryption - Set false if no custom encryption -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
